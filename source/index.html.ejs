                        'werden. Alle benötigten Abhängigkeiten zum ' +
                        'Aufsetzen sind durch eine einfache posix-Umgebung ' +
                        'gegeben wie Busybox oder ArchLinux selbst.'
                    ]
                }
            },
            {
                title: 'backup-rotation',
                url: 'https://torben.website/backup-rotation',
                content: {
                    enUS: [
                        'This script allows you to create a local or remote ' +
                        'backup rotation for your files.'
                    ],
                    deDE: [
                        'Mit diesem Skript können Sie eine lokale oder ' +
                        'remote Datensicherung mit Rotationsplan für Ihre ' +
                        'Dateien einrichten.'
                    ]
                }
            },
            {
                title: 'reachable-watcher',
                url: 'https://torben.website/reachable-watcher',
                content: {
                    enUS: [
                        'As simple configurable script to ensure ' +
                        'reachability of various web servers. Status codes ' +
                        'can be checked and emails send if something is ' +
                        'unexpected.'
                    ],
                    deDE: [
                        'Ein einfach zu konfigurierendes Skript, um die ' +
                        'Erreichbarkeit verschiedener Webserver ' +
                        'sicherzustellen. Es können Statuscodes überprüft ' +
                        'und E-Mails versendet werden, falls etwas ' +
                        'Unerwartetes auftritt.'
                    ]
                }
            }
        ]
    }
]
// endregion
_%>
<html class="hp-no-javascript" lang="en">
    <!--region head-->
    <head>
        <meta charset="utf-8">
        <meta
            name="description"
            content="bash design development responsive javascript"
        >
        <meta name="author" content="Torben Sickert">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta
            name="google-site-verification"
            content="1_qh0NqpYkHYZeDLXPujeE6dzcpozXmOLItTv7hbbXU"
        >
        <base href="/">
        <title>Torben Sickert development</title>
        <%- _.include(
            'web-component-wrapper/polyfill.html', {webComponents: false}
        ) %>
        <script>
            AUTO_DEFINE_HOME_PAGE = true

            window.document.documentElement.classList.remove('hp-no-javascript')
            window.document.documentElement.classList.add('hp-javascript')
        </script>
    </head>
    <!--endregion-->
    <!--region body-->
    <body class="hp-no-javascript">
        <script>
            window.document.body.classList.remove('hp-no-javascript')
            window.document.body.classList.add('hp-javascript')
        </script>

        <div class="wu-window-loading-cover">
            <div class="loading-text">
                <lang-replace>
                    <span>L</span>
                    <span>O</span>
                    <span>A</span>
                    <span>D</span>
                    <span>I</span>
                    <span>N</span>
                    <span>G</span>
                </lang-replace>
                <!--<%- ALTERNATE_LANGUAGE %>:
                    <span>L</span>
                    <span>A</span>
                    <span>D</span>
                    <span>E</span>
                -->
            </div>
        </div>

        <home-page class="hp wu">
            <!--region header-->
            <header
                class="hp-header headroom wu-start-up-animation-number-<%- getStartUpAnimationNumber() %>"
            >
                <div class="hp-header__center">
                    <nav role="navigation" class="wu-priority-navigation">
                        <ul class="wu-priority-navigation__list">
                            <%_
                            let first = true
                            for (const section of SECTIONS) {
                            _%>
                                <%_ if (section.content.menuLabel) { _%>
                                    <li
                                        class="wu-start-up-animation-number-<%- getStartUpAnimationNumber() %>"
                                    >
                                        <a
                                            class="wu-priority-navigation__link"
                                            href="#<%- section.title %>"
                                        >
                                            <%- section.content.menuLabel[DEFAULT_LANGUAGE] %>
                                            <!--<%- ALTERNATE_LANGUAGE %>:
                                                <%- section.content.menuLabel[ALTERNATE_LANGUAGE] %>
                                            -->
                                        </a>
                                    </li>
                                <%_ } _%>
                                <%_ first = false _%>
                            <%_ } _%>

                            <li class="wu-priority-navigation__list__overflow-indicator">
                                <div
                                    class="wu-priority-navigation__list__overflow-indicator__title"
                                >
                                    <div
                                        class="wu-priority-navigation__list__overflow-indicator__title__icon"
                                    ></div>
                                </div>
                            </li>
                        </ul>

                        <ul class="wu-priority-navigation__overflow-list"></ul>
                    </nav>

                    <a
                        class="hp-switch-language wu-start-up-animation-number-<%- getStartUpAnimationNumber() %>"
                        href="#lang-<%- ALTERNATE_LANGUAGE %>"
                    >
                        <%- ALTERNATE_LANGUAGE.substring(0, ALTERNATE_LANGUAGE.length - 2) %>
                    </a>
                </div>
            </header>
            <!-- endregion-->
            <main class="wu-router-outlet">
                <!--region swiper-->
                <section class="hp-section swiper" data-website-utilities-section>
                    <div class="hp-section__swiper-wrapper swiper-wrapper">
                    <%_ for (const section of SECTIONS) { _%>
                        <div
                            data-hash="<%- section.title %>"
                            class="hp-section__swiper-wrapper__slide hp-section__swiper-wrapper__slide--<%- section.title %> swiper-slide"
                        >
                            <div class="hp-section__swiper-wrapper__slide__image">
                                <div class="hp-section__swiper-wrapper__slide__center">
                                    <!--
                                        Serves as anchor point if JavaScript
                                        isn't supported.
                                    -->
                                    <h1 id="<%- section.title %>">
                                        <%_ if (section.content.headline) { _%>
                                            <%- section.content.headline[DEFAULT_LANGUAGE] %>
                                            <!--<%- ALTERNATE_LANGUAGE %>:
                                                <%- section.content.headline[ALTERNATE_LANGUAGE] %>
                                            -->
                                        <%_ } _%>
                                    </h1>

                                    <%_ if (section.content.sound) { _%>
                                        <lang-alternative
                                            class="hp-audio-player" active
                                        >
                                            <pre hidden>
                                                <%- section.content.sound[DEFAULT_LANGUAGE] %>
                                            </pre>
                                        </lang-alternative>
                                        <lang-alternative
                                            lang="<%- ALTERNATE_LANGUAGE %>"
                                            class="hp-audio-player"
                                        >
                                            <pre hidden>
                                                <%- section.content.sound[ALTERNATE_LANGUAGE] %>
                                            </pre>
                                        </lang-alternative>
                                    <%_ } %>

                                    <%_ if (section.title === 'work') { _%>
                                        <h2>
                                            <%- section.content.subHeadline[DEFAULT_LANGUAGE] %>
                                            <!--<%- ALTERNATE_LANGUAGE %>:
                                                <%- section.content.subHeadline[ALTERNATE_LANGUAGE] %>
                                            -->
                                        </h2>

                                        <p>
                                            <lang-replace>
                                                <%_ for (const keywords of section.content.keywords[DEFAULT_LANGUAGE]) { _%>
                                                    <%_ if (keywords.title) { _%>
                                                        <strong><%- keywords.title %></strong>
                                                    <%_ } _%>
                                                    <%- keywords.content.join(', ') %>
                                                <%_ } _%>
                                            </lang-replace>
                                            <!--<%- ALTERNATE_LANGUAGE %>:
                                                <%_ for (const keywords of section.content.keywords[ALTERNATE_LANGUAGE]) { _%>
                                                    <%_ if (keywords.title) { _%>
                                                        _%>
                                                        <strong><%- keywords.title %></strong>
                                                    <%_ } _%>
                                                    <%- keywords.content.join(', ') %>
                                                <%_ } _%>
                                            -->
                                        </p>

                                        <h2>
                                            <%- section.content.subHeadline2[DEFAULT_LANGUAGE] %>
                                            <!--<%- ALTERNATE_LANGUAGE %>:
                                                <%- section.content.subHeadline2[ALTERNATE_LANGUAGE] %>
                                            -->
                                        </h2>

                                        <%_ for (const group of PROJECTS) { _%>
                                            <h3>
                                                <%- group.title[DEFAULT_LANGUAGE] %>
                                                <!--<%- ALTERNATE_LANGUAGE %>:
                                                        <%- group.title[ALTERNATE_LANGUAGE] %>
                                                    -->
                                            </h3>

                                            <div class="hp-projects">
                                                <%_ for (const project of group.content) { _%>
                                                    <div class="hp-card">
                                                        <div class="hp-card__body">
                                                            <h4>
                                                                <%_ if (project.url) { %>
                                                                    <a
                                                                        href="<%- project.url %>"
                                                                        target="_blank"
                                                                    >
                                                                        <%- project.title %>
                                                                    </a>
                                                                <%_ } else  { %>
                                                                    <%- project.title %>
                                                                <%_ } %>
                                                            </h4>

                                                            <%_ if (project.images) { %>
                                                                <div class="swiper">
                                                                    <!-- Additional required wrapper -->
                                                                    <div class="swiper-wrapper">
                                                                        <%_ for (const url of project.images) { _%>
                                                                            <div class="swiper-slide">
                                                                                <img
                                                                                        class="hp-card__body__image"
                                                                                        src="<%- url %>"
                                                                                        alt="<%- project.title %>"
                                                                                >
                                                                            </div>
                                                                        <%_ } %>
                                                                    </div>
                                                                    <div class="swiper-pagination"></div>
                                                                </div>
                                                            <%_ } %>

                                                            <p>
                                                                <%- project.content[DEFAULT_LANGUAGE][0] %>
                                                                <!--<%- ALTERNATE_LANGUAGE %>:
                                                                    <%- project.content[ALTERNATE_LANGUAGE][0] %>
                                                                -->
                                                                <%_ if (project.content[DEFAULT_LANGUAGE].length > 1) {_%>
                                                                    <ul>
                                                                        <%_
                                                                        let index = 0
                                                                        for (const element of project.content[DEFAULT_LANGUAGE][1]) {
                                                                        _%>
                                                                            <li>
                                                                                <%_ if (Array.isArray(element)) { _%>
                                                                                    <lang-replace>
                                                                                        <a
                                                                                            href="<%- element[1] %>"
                                                                                        >
                                                                                            <%- element[0] %>
                                                                                        </a>
                                                                                    </lang-relace>
                                                                                    <!--<%- ALTERNATE_LANGUAGE %>:

                                                                                        <%- ALTERNATE_LANGUAGE %>:
                                                                                        <a
                                                                                            href="<%- project.content[ALTERNATE_LANGUAGE][1][index][1] %>"
                                                                                        >
                                                                                            <%- project.content[ALTERNATE_LANGUAGE][1][index][0] %>
                                                                                        </a>
                                                                                    -->
                                                                                <%_ } else { _%>
                                                                                    <%- element %>
                                                                                    <!--<%- ALTERNATE_LANGUAGE %>:
                                                                                        <%- project.content[ALTERNATE_LANGUAGE][1][index] %>
                                                                                    -->
                                                                                <%_ } _%>
                                                                            </li>
                                                                            <%_
                                                                            index += 1
                                                                        }
                                                                        _%>
                                                                    </ul>
                                                                <%_ } _%>
                                                            </p>
                                                        </div>
                                                    </div>
                                                <%_ } _%>
                                            </div>
                                        <%_ } _%>
                                    <%_ } else { _%>
                                        <p class="lead">
                                            <%- section.content.lead[DEFAULT_LANGUAGE] %>
                                            <!--<%- ALTERNATE_LANGUAGE %>:
                                                <%- section.content.lead[ALTERNATE_LANGUAGE] %>
                                            -->
                                            <%_ if (section.title === 'about-me') { _%>
                                                <span>
                                                    <lang-replace>
                                                        <a
                                                            href="<%- LINK_CURRICULUM_VITAE_DEFAULT_LANGUAGE_PATH %>"
                                                            target="_blank"
                                                        >Curriculum Vitae</a>
                                                    </lang-replace>
                                                    <!--<%- ALTERNATE_LANGUAGE %>:
                                                        <a
                                                            href="<%- LINK_CURRICULUM_VITAE_ALTERNATE_LANGUAGE_PATH %>"
                                                            target="_blank"
                                                        >Lebenslauf</a>
                                                    -->

                                                    <a
                                                        href="<%- LINK_V_CARD_PATH %>"
                                                        target="_blank"
                                                    >vCard</a>
                                                </span>
                                            <%_ } _%>
                                        </p>
                                    <%_ } _%>
                                    <%_ if (section.title === 'contact') { _%>
                                        <a href="tel:004917610248185">
                                            Phone<!--<%- ALTERNATE_LANGUAGE %>:Tel.-->
                                            +49 (0) 176 <span>/</span> 10 248 185
                                        </a>
                                        <p
                                            class="hp-section__swiper-wrapper__slide__center__social-links"
                                        >
                                            <%_
                                                for (const link of SOCIAL_MEDIA) {
                                                    if (link.url.indexOf('@') !== -1)
                                                        link.url = `mailto:${link.url}`
                                            _%>
                                                <a
                                                    href="<%- link.url %>"
                                                    target="_blank"
                                                >
                                                    <i class="bi bi-<%- link.icon %>"></i>
                                                    <span><%- link.title %></span>
                                                </a>
                                            <%_ } _%>
                                        </p>
                                    <%_ } _%>
                                </div>
                            </div>
                        </div>
                    <%_ } _%>
                    </div>

                    <div class="swiper-pagination"></div>

                    <div class="swiper-button-prev"></div>
                    <div class="swiper-button-next"></div>
                </section>
                <!--endregion-->
                <!--region about this website-->
                <section
                    class="about-this-website"
                    data-website-utilities-section="about-this-website"
                >
                    <div class="about-this-website__center">
                        <h1 id="about-this-website">
                            About this website
                            <!--<%- ALTERNATE_LANGUAGE %>:Impressum-->
                        </h1>
                        <h2>
                            Contact
                            <!--<%- ALTERNATE_LANGUAGE %>:Kontakt-->
                        </h2>
                        <div>
                            Provider of<!--<%- ALTERNATE_LANGUAGE %>:Anbieter von-->:
                            <a
                                class="<%- SOCIAL_MEDIA[SOCIAL_MEDIA.length - 1].title %>"
                                href="<%- SOCIAL_MEDIA[SOCIAL_MEDIA.length - 1].url %>"
                            ><%- SOCIAL_MEDIA[SOCIAL_MEDIA.length - 1].url %></a>
                            <br />
                            Torben Sickert
                            <br />
                            Waldstraße 29
                            <br />
                            79194 Gundelfingen i.Br.
                            <br />
                            Phone<!--<%- ALTERNATE_LANGUAGE %>:Tel.-->:
                            <a href="tel:004917610248185">
                                +49 (0) 176<span>/</span>10 248 185
                            </a>
                            <br />
                            Email:<!--<%- ALTERNATE_LANGUAGE %>:E-Mail-->
                            <a href="mailto:<%- SOCIAL_MEDIA[0].url %>">
                                <%- SOCIAL_MEDIA[0].url %>
                            </a>
                            <br />
                            Website<!--<%- ALTERNATE_LANGUAGE %>:Webseite-->:
                            <a
                                class="<%- SOCIAL_MEDIA[SOCIAL_MEDIA.length - 1].title %>"
                                href="<%- SOCIAL_MEDIA[SOCIAL_MEDIA.length - 1].url %>"
                            ><%- SOCIAL_MEDIA[SOCIAL_MEDIA.length - 1].url %></a>
                            <br />
                            <br />
                            <a
                                href="<%- LINK_PUBLIC_SSH_KEY_PATH %>"
                                target="_blank"
                            >
                                public ssh key
                                <!--<%- ALTERNATE_LANGUAGE %>:
                                    öffentlicher SSH-Schlüssel
                                -->
                            </a>
                        </div>
                        <%- _.include('legal-notes') %>
                    </div>
                </section>
                <!-- endregion -->
            </main>
            <!--region footer-->
            <!--
                Wrap the footer of the page in another container to center the
                content.
            -->
            <footer
                class="wu-start-up-animation-number-<%- getStartUpAnimationNumber() %>"
            >
                <p>
                    &copy; 2013 Torben Sickert &middot;
                    <a href="#about-this-website">
                        about this website
                        <!--<%- ALTERNATE_LANGUAGE %>:Impressum-->
                    </a>
                </p>
            </footer>
            <!--endregion-->
            <a class="wu-scroll-to-top" href="#top">
                top<!--deDE:nach oben--></a>
            </a>
        </home-page>
        <%_ if (_.configuration.offline) { _%>
            <noscript>
                <iframe src="manifest.html" style="display: none"></iframe>
            </noscript>
        <%_ } _%>
    </body>
    <!--endregion-->
</html>
